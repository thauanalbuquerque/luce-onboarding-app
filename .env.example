# Configuração do envio das respostas ao n8n (v2 — Opção C).
# Copie para .env e preencha. O .env NÃO é versionado.
#
# OBS: estes valores NÃO são segredo de verdade — como o app é estático e
# público, eles acabam visíveis no JS final. O segredo real (service key do
# Supabase) fica só no n8n. O token aqui apenas deter spam casual.

# URL pública do webhook do n8n (workflow "Onboarding · Persistência (v2)").
VITE_ONBOARDING_WEBHOOK_URL=https://luce.tulibertadvida.com/webhook/onboarding

# Token leve compartilhado — deve ser IGUAL ao conferido no workflow do n8n.
VITE_ONBOARDING_TOKEN=troque-pelo-token-compartilhado
